// Molat Frisør — booking schema
// Lokalt + Vercel: PostgreSQL.
// Anbefales: Vercel Postgres (Neon-backed) eller egen Neon/Supabase-instans.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id            String   @id @default(cuid())
  customerName  String
  customerPhone String
  customerEmail String
  serviceId     String   @default("voksen")
  servicePrice  Int      @default(400)
  startsAt      DateTime
  endsAt        DateTime
  status        String   @default("CONFIRMED") // CONFIRMED | CANCELLED
  googleEventId String?
  notes         String?
  createdAt     DateTime @default(now())

  @@index([startsAt])
  @@index([status])
}

model Block {
  id        String   @id @default(cuid())
  startsAt  DateTime
  endsAt    DateTime
  reason    String?
  createdAt DateTime @default(now())

  @@index([startsAt])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model SiteContent {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model SiteImage {
  slot      String   @id // f.eks. "gallery-1"
  url       String
  updatedAt DateTime @updatedAt
}
